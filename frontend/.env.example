# Backend API (recommended). Run state and "Logs: Backend" use this. No Supabase required.
# Run the backend: cd med-assist/backend && uvicorn api_server:app --reload --port 8000
VITE_API_URL=http://localhost:8000

# Supabase (optional). Only needed if you want "Logs: Supabase". Omit these to use backend + frontend only.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
